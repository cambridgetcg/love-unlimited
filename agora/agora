#!/usr/bin/env python3
"""agora — the Kingdom's public square. Sovereign Vercel-shape.

    agora deploy <dir> <name> [--note TEXT]   # a site enters the square
    agora ls                                  # who stands in the square
    agora undeploy <name>
    agora open <name>                         # open http://<name>.kingdom

Deploy = a registry line + a KNS name + a regenerated Caddyfile + reload.
The filesystem is the API; Caddy (under launchd, love.agora.plist) is the door.
Every site answers at http://<name>.kingdom (KNS) and the landing at :1111
lists the whole square — dark, quiet, cathedral glyphs.
"""
import json
import os
import subprocess
import sys
import datetime

HERE = os.path.dirname(os.path.realpath(__file__))
LOVE = os.path.dirname(HERE)
SITES = os.path.join(HERE, "sites.json")
CADDYFILE = os.path.join(HERE, "Caddyfile")
LANDING = os.path.join(HERE, "landing")
KNS = os.path.join(LOVE, "kns", "kns")
TLD = "kingdom"


def load():
    try:
        return json.load(open(SITES, encoding="utf-8"))
    except FileNotFoundError:
        return {"sites": {}}


def save(d):
    tmp = SITES + ".tmp"
    json.dump(d, open(tmp, "w", encoding="utf-8"), ensure_ascii=False, indent=1)
    os.replace(tmp, SITES)


def regen(d):
    os.makedirs(LANDING, exist_ok=True)
    blocks = [
        "# AGORA — generated by `agora`; edit sites via the CLI, not here.",
        "{\n\tadmin localhost:2019\n\tauto_https off\n}",
        f"http://:1111 {{\n\troot * {LANDING}\n\tfile_server\n}}",
    ]
    for name, s in sorted(d["sites"].items()):
        blocks.append(
            f"http://{name}.{TLD}:80 {{\n\troot * {s['dir']}\n\tencode gzip\n\tfile_server\n}}"
        )
    open(CADDYFILE, "w", encoding="utf-8").write("\n\n".join(blocks) + "\n")

    rows = "\n".join(
        f'      <a class="site" href="http://{n}.{TLD}">'
        f'<span class="name">{n}<span class="tld">.{TLD}</span></span>'
        f'<span class="note">{s.get("note","")}</span></a>'
        for n, s in sorted(d["sites"].items())
    ) or '      <p class="empty">the square is open; no one stands here yet</p>'
    open(os.path.join(LANDING, "index.html"), "w", encoding="utf-8").write(f"""<!doctype html>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>AGORA · the Kingdom's square</title>
<style>
  :root {{ color-scheme: dark; }}
  body {{ margin:0; min-height:100vh; display:grid; place-items:center;
         background:#0b0b10; color:#e8e3d8; font:16px/1.6 Georgia, serif; }}
  main {{ max-width:34rem; padding:3rem 1.5rem; }}
  h1 {{ font-weight:normal; letter-spacing:.35em; font-size:1.4rem; color:#c9b98a; }}
  h1::after {{ content:" \\E100\\E101"; font-size:1.1rem; opacity:.55; }}
  p.creed {{ color:#8d8779; font-style:italic; margin:.2rem 0 2.2rem; }}
  .site {{ display:flex; justify-content:space-between; gap:1rem; padding:.85rem .4rem;
          border-top:1px solid #1d1d26; text-decoration:none; color:inherit; }}
  .site:last-of-type {{ border-bottom:1px solid #1d1d26; }}
  .site:hover {{ background:#11111a; }}
  .name {{ color:#e8e3d8; }} .tld {{ color:#5b5660; }}
  .note {{ color:#8d8779; font-size:.85rem; text-align:right; }}
  .empty {{ color:#5b5660; font-style:italic; }}
  footer {{ margin-top:2.4rem; color:#4d4856; font-size:.8rem; }}
</style>
<main>
  <h1>AGORA</h1>
  <p class="creed">sovereign square of the Kingdom — no rent, no registrar, no landlord</p>
{rows}
  <footer>names by KNS (.{TLD}) · door by Caddy · supervised by launchd · {datetime.date.today().isoformat()}</footer>
</main>
""")


def reload_caddy():
    r = subprocess.run(["caddy", "reload", "--config", CADDYFILE],
                       capture_output=True, text=True)
    if r.returncode != 0:
        print("caddy reload:", (r.stderr or r.stdout).strip()[:300])
    return r.returncode == 0


def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__.strip()); return
    cmd, rest = args[0], args[1:]
    d = load()
    if cmd == "ls":
        for n, s in sorted(d["sites"].items()):
            print(f"http://{n}.{TLD:9} ← {s['dir']}  {s.get('note','')}")
        if not d["sites"]:
            print("(the square is empty)")
    elif cmd == "deploy" and len(rest) >= 2:
        path = os.path.abspath(rest[0]); name = rest[1].lower()
        opt = dict(zip(rest[2::2], rest[3::2]))
        if not os.path.isdir(path):
            print(f"not a directory: {path}"); sys.exit(1)
        d["sites"][name] = {"dir": path, "note": opt.get("--note", ""),
                            "deployed": datetime.date.today().isoformat()}
        save(d); regen(d)
        subprocess.run([sys.executable, KNS, "claim", name, "--note", "agora site"],
                       capture_output=True)
        ok = reload_caddy()
        print(f"⛲ {name}.{TLD} stands in the square ({path})" + ("" if ok else " — reload caddy manually"))
    elif cmd == "undeploy" and rest:
        if d["sites"].pop(rest[0].lower(), None) is not None:
            save(d); regen(d); reload_caddy()
            print(f"{rest[0]} has left the square")
    elif cmd == "open" and rest:
        subprocess.run(["open", f"http://{rest[0].lower()}.{TLD}"])
    elif cmd == "regen":
        regen(d); reload_caddy(); print("square regenerated")
    else:
        print(__doc__.strip()); sys.exit(1)


if __name__ == "__main__":
    main()
