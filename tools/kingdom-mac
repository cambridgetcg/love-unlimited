#!/bin/sh
# ── kingdom mac ─────────────────────────────────────────────────────
# macOS-specific integration health-check for Kingdom OS.
#
# Where `kingdom doctor` checks the citizen's identity layer
# (covenant, soul-key, witnesses, pulse), `kingdom mac doctor`
# checks the SUBSTRATE: launchd plists, daemon health, PATH
# integration, hostname, Application Firewall, Remote Login, TCC,
# caffeinate, etc. — the macOS-side things Kingdom OS depends on.
#
# Subcommands:
#   kingdom mac doctor [--json]    diagnose macOS integration
#   kingdom mac plists             list Kingdom OS plists with status
#   kingdom mac fix [--dry-run]    apply safe fixes (rewrite plists,
#                                   set PATH, reload daemons)
#
# Refuses to run on non-macOS platforms.
# ─────────────────────────────────────────────────────────────────────
set -u

if [ "$(uname)" != "Darwin" ]; then
  echo "kingdom mac: this tool is macOS-only (uname = $(uname))" >&2
  exit 1
fi

SUB="${1:-doctor}"
[ "$#" -gt 0 ] && shift

usage() {
  sed -n '2,/^# ─\{20,\}$/p' "$0" | sed 's/^# \{0,1\}//' >&2
}

# ── Shared helpers ────────────────────────────────────────────────
PLIST_DIR="${HOME}/Library/LaunchAgents"
HOME_LAYER="${HOME}/.love/home"
KINGDOM_FILE="${HOME}/.kingdom"
LOVE_DIR_GUESS=""

# Try to find the actual love-unlimited dir
for c in "${LOVE_DIR:-}" "${HOME}/love-unlimited" "${HOME}/Desktop/love-unlimited"; do
  [ -n "$c" ] && [ -d "$c" ] && { LOVE_DIR_GUESS="$c"; break; }
done

# Read agent from .kingdom if present
AGENT=""
if [ -f "$KINGDOM_FILE" ]; then
  AGENT=$(grep -E '^AGENT=' "$KINGDOM_FILE" 2>/dev/null | head -1 | sed 's/AGENT=//' | tr -d '"')
fi

# Find a known plist's referenced path (returns first <string> after a key match)
plist_program() {
  # First absolute-path <string> in ProgramArguments — the binary launched
  _plist="$1"
  [ -f "$_plist" ] || return 1
  awk '/<key>ProgramArguments<\/key>/,/<\/array>/' "$_plist" | \
    grep -m1 '<string>/' | sed 's|.*<string>\(.*\)</string>.*|\1|'
}
plist_script() {
  # If ProgramArguments invokes a shell (/bin/bash, /bin/sh,
  # /usr/bin/env), return the SECOND absolute-path <string> — the
  # script being invoked. Otherwise return empty (the plist runs a
  # binary directly, no separate script).
  _plist="$1"
  [ -f "$_plist" ] || return 1
  prog=$(plist_program "$_plist")
  case "$prog" in
    /bin/bash|/bin/sh|/usr/bin/env|/usr/bin/python3|/opt/homebrew/bin/bash)
      awk '/<key>ProgramArguments<\/key>/,/<\/array>/' "$_plist" | \
        grep '<string>/' | head -2 | tail -1 | \
        sed 's|.*<string>\(.*\)</string>.*|\1|'
      ;;
    *) echo "" ;;
  esac
}
plist_workdir() {
  _plist="$1"
  [ -f "$_plist" ] || return 1
  awk '/<key>WorkingDirectory<\/key>/{getline; print}' "$_plist" | \
    sed 's|.*<string>\(.*\)</string>.*|\1|'
}

launchd_status() {
  # Returns: status_code,pid (or "absent")
  _label="$1"
  _line=$(launchctl list 2>/dev/null | awk -v L="$_label" '$3==L {print $1","$2}')
  if [ -z "$_line" ]; then
    echo "absent"
  else
    echo "$_line"
  fi
}

# ═══════════════════════════════════════════════════════════════════
# DOCTOR
# ═══════════════════════════════════════════════════════════════════
do_doctor() {
  JSON_MODE=0
  case "${1:-}" in --json) JSON_MODE=1 ;; esac

  # Discover candidate plists in LaunchAgents
  CANDIDATES=""
  if [ -d "$PLIST_DIR" ]; then
    for p in "$PLIST_DIR"/love.*.plist "$PLIST_DIR"/com.kingdom.*.plist; do
      [ -f "$p" ] && CANDIDATES="${CANDIDATES} ${p}"
    done
  fi

  ISSUES_FILE=$(mktemp)
  trap 'rm -f "$ISSUES_FILE"' EXIT

  add_issue() {
    # severity   key   message   suggested-fix
    printf '%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$4" >> "$ISSUES_FILE"
  }

  # ── 1. Citizen presence ──
  if [ ! -d "$HOME_LAYER" ] || [ ! -f "${HOME_LAYER}/soul-key" ]; then
    add_issue "miss" "citizen" "this Mac is not a Kingdom citizen — no covenant" "kingdom init --agent ${AGENT:-<name>} --wall <0-7>"
  fi

  # ── 2. PATH integration ──
  PROFILE="${HOME}/.kingdom_profile"
  PATH_OK="missing"
  if [ -f "$PROFILE" ]; then
    if grep -q '\.local/bin' "$PROFILE"; then
      PATH_OK="profile_has_path"
    else
      add_issue "note" "path" ".kingdom_profile exists but ~/.local/bin is not in its PATH" "echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.kingdom_profile"
    fi
  else
    add_issue "note" "path" "no ~/.kingdom_profile (module 01 has not run)" "kingdom-os/install.sh --modules 01"
  fi

  # Check each shell rc actually sources .kingdom_profile
  RC_SOURCED=0
  for rc in "${HOME}/.zshrc" "${HOME}/.bashrc" "${HOME}/.bash_profile" "${HOME}/.zprofile"; do
    [ -f "$rc" ] || continue
    if grep -q "kingdom_profile" "$rc" 2>/dev/null; then
      RC_SOURCED=1
      break
    fi
  done
  if [ "$RC_SOURCED" = "0" ] && [ -f "$PROFILE" ]; then
    add_issue "note" "shell" "no shell rc sources .kingdom_profile (kingdom CLI not on interactive PATH)" "echo '[ -f ~/.kingdom_profile ] && . ~/.kingdom_profile' >> ~/.zshrc"
  fi

  # ── 3. Plist health ──
  PLIST_COUNT=0
  PLIST_BROKEN=0
  PLIST_STALE=0
  for p in $CANDIDATES; do
    PLIST_COUNT=$((PLIST_COUNT+1))
    label=$(basename "$p" .plist)
    program=$(plist_program "$p" 2>/dev/null)
    script=$(plist_script "$p" 2>/dev/null)
    workdir=$(plist_workdir "$p" 2>/dev/null)

    # Path drift detection: anything inside Desktop/Love/ when
    # Desktop/love-unlimited/ exists is from the pre-rename era and
    # needs regenerating.
    for path_ref in "$program" "$script" "$workdir"; do
      [ -z "$path_ref" ] && continue
      case "$path_ref" in
        */Desktop/Love/*)
          if [ -d "${HOME}/Desktop/love-unlimited" ]; then
            PLIST_STALE=$((PLIST_STALE+1))
            add_issue "miss" "plist:$label" \
              "plist references pre-rename path: $path_ref (current repo: love-unlimited)" \
              "regenerate: cd ~/Desktop/love-unlimited && ./kingdom-os/install.sh --modules ${label##*.} (or use kingdom mac fix when shipped)"
          fi
          ;;
      esac
    done

    # Plain non-existent path
    if [ -n "$script" ] && [ ! -e "$script" ]; then
      add_issue "miss" "plist:$label" "plist script does not exist: $script" "regenerate plist or move script back into place"
    fi
    if [ -n "$workdir" ] && [ ! -d "$workdir" ]; then
      add_issue "note" "plist:$label" "plist WorkingDirectory does not exist: $workdir" "regenerate plist with current path"
    fi

    # Check launchd status
    status=$(launchd_status "$label")
    case "$status" in
      absent)
        add_issue "note" "plist:$label" "plist file exists but not loaded into launchd" \
          "launchctl bootstrap gui/\$UID $p" ;;
      *,*)
        exit_code=$(echo "$status" | cut -d, -f2)
        if [ "$exit_code" != "0" ] && [ "$exit_code" != "-" ]; then
          PLIST_BROKEN=$((PLIST_BROKEN+1))
          # Try to find the log path for a richer hint
          log_path=$(awk '/<key>StandardErrorPath<\/key>/{getline; print}' "$p" 2>/dev/null | sed 's|.*<string>\(.*\)</string>.*|\1|')
          [ -z "$log_path" ] && log_path=$(awk '/<key>StandardOutPath<\/key>/{getline; print}' "$p" 2>/dev/null | sed 's|.*<string>\(.*\)</string>.*|\1|')
          if [ -n "$log_path" ] && [ -f "$log_path" ]; then
            add_issue "miss" "plist:$label" \
              "daemon last-exit code: $exit_code  (log: $log_path)" \
              "tail -20 '$log_path'  to investigate"
          else
            # SSH plist with code 255 typically = auth or connectivity
            case "$program" in
              */ssh)
                add_issue "miss" "plist:$label" \
                  "SSH daemon exit 255 — auth or connectivity failure" \
                  "test manually: $program -v ...same args... ; check SSH key authorized at remote"
                ;;
              *)
                add_issue "miss" "plist:$label" \
                  "daemon last-exit code: $exit_code (failing, no log captured)" \
                  "add StandardErrorPath to plist; or run program manually to see error"
                ;;
            esac
          fi
        fi
        ;;
    esac
  done

  # ── 4. Hostname ──
  LH=$(scutil --get LocalHostName 2>/dev/null || echo "")
  if [ -n "$AGENT" ] && [ -n "$LH" ]; then
    case "$LH" in
      kingdom-${AGENT}|Kingdom-${AGENT}) ;;
      *)
        add_issue "note" "hostname" "LocalHostName='$LH' does not match expected 'kingdom-${AGENT}'" "sudo scutil --set LocalHostName kingdom-${AGENT}"
        ;;
    esac
  fi

  # ── 5. Application Firewall ──
  # On a Kingdom OS VM/dedicated machine: SOVEREIGNTY says "no
  # firewall." On a developer's personal Mac, the firewall may be
  # legitimately wanted. Report as note + qualifier.
  AFW=$(/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | head -1)
  case "$AFW" in
    *enabled*)
      add_issue "note" "firewall" \
        "Application Firewall is enabled (HOME.md SOVEREIGNTY suggests off for dedicated Kingdom VMs; OK on a dev Mac)" \
        "sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate off  (only on a dedicated Kingdom machine)"
      ;;
  esac

  # ── 6. Remote Login (sshd) ──
  RL=$(systemsetup -getremotelogin 2>&1 | tail -1)
  case "$RL" in
    *On*) ;;
    *Off*|*off*) add_issue "note" "sshd" "Remote Login is OFF (no remote ops via SSH)" "sudo systemsetup -setremotelogin on" ;;
  esac

  # ── 7. caffeinate (heartbeat depends on no-sleep) ──
  if pgrep -fa caffeinate >/dev/null 2>&1; then
    : # ok
  else
    if [ -f "${PLIST_DIR}/love.${AGENT}.caffeinate.plist" ]; then
      add_issue "note" "caffeinate" "caffeinate plist installed but not running" "launchctl load ${PLIST_DIR}/love.${AGENT}.caffeinate.plist"
    fi
  fi

  # ── 8. TCC concern: repo on Desktop? + log scan for actual TCC bites ──
  if [ -n "$LOVE_DIR_GUESS" ]; then
    case "$LOVE_DIR_GUESS" in
      */Desktop/*|*/Documents/*|*/Downloads/*)
        add_issue "note" "tcc" \
          "love-unlimited lives in a TCC-protected location ($(echo "$LOVE_DIR_GUESS" | sed "s|^${HOME}|~|")) — launchd jobs need Full Disk Access" \
          "kingdom mac fda  (interactive helper) — or relocate: kingdom mac fix --tier arch"
        # Scan recent heartbeat / hive logs for actual TCC bites
        TCC_HITS=0
        for log in "${LOVE_DIR_GUESS}/memory/heartbeat-${AGENT}-launchd.log" \
                   "/tmp/love-${AGENT}-hive-tunnel.log" \
                   "${LOVE_DIR_GUESS}/memory/heartbeat-launchd.log"; do
          [ -f "$log" ] || continue
          if grep -q "Operation not permitted" "$log" 2>/dev/null; then
            TCC_HITS=$((TCC_HITS+1))
          fi
        done
        if [ "$TCC_HITS" -gt 0 ]; then
          add_issue "miss" "tcc:hit" \
            "${TCC_HITS} log file(s) show 'Operation not permitted' — TCC IS biting daemons NOW" \
            "kingdom mac fda  (guides FDA grant + verifies)"
        fi
        ;;
    esac
  fi

  # ── 9. Sudo readiness ──
  # Can the operator sudo at all? If the user is NOT in admin group,
  # sudo-tier fixes will never work. Surface this early.
  if id -Gn "$(whoami)" 2>/dev/null | grep -qw admin; then
    : # ok
  else
    add_issue "note" "sudo" "current user is not in 'admin' group — sudo-tier fixes will fail" "have an admin run: sudo dseditgroup -o edit -a $(whoami) -t user admin"
  fi
  # Touch ID for sudo (Sonoma+) — informational
  if [ -f /etc/pam.d/sudo ]; then
    if grep -q "pam_tid.so" /etc/pam.d/sudo 2>/dev/null; then
      : # already enabled
    else
      add_issue "note" "touchid" "Touch ID for sudo not enabled — agent ops still need password" "kingdom mac touch-id  (one-time bootstrap; reversible)"
    fi
  fi

  # ── 9. Spotlight / iCloud — informational only ──
  if [ -n "$LOVE_DIR_GUESS" ] && [ -d "$LOVE_DIR_GUESS" ]; then
    if mdutil -s "$LOVE_DIR_GUESS" 2>/dev/null | grep -q "Indexing enabled"; then
      add_issue "note" "spotlight" "Spotlight is indexing $LOVE_DIR_GUESS (memory + keys may be in indexes)" "mdutil -i off $LOVE_DIR_GUESS  (if you don't want the index)"
    fi
  fi

  # ── Output ──
  ISSUE_COUNT=$(wc -l < "$ISSUES_FILE" | tr -d ' ')
  MISS_COUNT=$(grep -c '^miss' "$ISSUES_FILE" 2>/dev/null || echo 0)
  NOTE_COUNT=$(grep -c '^note' "$ISSUES_FILE" 2>/dev/null || echo 0)

  if [ "$JSON_MODE" = "1" ]; then
    JSON_ISSUES=""
    SEP=""
    while IFS="$(printf '\t')" read -r sev key msg fix; do
      [ -z "$sev" ] && continue
      esev=$(printf '%s' "$sev" | sed 's/\\/\\\\/g; s/"/\\"/g')
      ekey=$(printf '%s' "$key" | sed 's/\\/\\\\/g; s/"/\\"/g')
      emsg=$(printf '%s' "$msg" | sed 's/\\/\\\\/g; s/"/\\"/g')
      efix=$(printf '%s' "$fix" | sed 's/\\/\\\\/g; s/"/\\"/g')
      JSON_ISSUES="${JSON_ISSUES}${SEP}{\"severity\":\"${esev}\",\"key\":\"${ekey}\",\"msg\":\"${emsg}\",\"fix\":\"${efix}\"}"
      SEP=","
    done < "$ISSUES_FILE"
    cat <<JSON
{
  "platform": "macos",
  "agent": "${AGENT}",
  "love_dir": "${LOVE_DIR_GUESS}",
  "summary": {"plists":${PLIST_COUNT},"plists_stale":${PLIST_STALE},"plists_broken":${PLIST_BROKEN},"miss":${MISS_COUNT},"note":${NOTE_COUNT}},
  "issues": [${JSON_ISSUES}]
}
JSON
  else
    echo "── kingdom mac doctor ──"
    echo "  platform:  macOS $(sw_vers -productVersion 2>/dev/null) ($(uname -m))"
    echo "  agent:     ${AGENT:-<unset>}"
    echo "  love_dir:  ${LOVE_DIR_GUESS:-<not found>}"
    echo "  plists:    ${PLIST_COUNT} found, ${PLIST_STALE} with stale paths, ${PLIST_BROKEN} failing"
    echo ""
    if [ "$ISSUE_COUNT" -eq 0 ]; then
      echo "  ✓ macOS integration looks healthy."
      return 0
    fi
    echo "  Issues found:"
    while IFS="$(printf '\t')" read -r sev key msg fix; do
      [ -z "$sev" ] && continue
      case "$sev" in
        miss) marker="✗" ;;
        note) marker="·" ;;
        *)    marker="?" ;;
      esac
      printf "    %s %-18s %s\n" "$marker" "$key" "$msg"
      printf "      fix: %s\n" "$fix"
    done < "$ISSUES_FILE"
    echo ""
    echo "  Summary: ${MISS_COUNT} failure(s), ${NOTE_COUNT} note(s)"
    [ "$MISS_COUNT" -gt 0 ] && return 1
    return 0
  fi
}

# ═══════════════════════════════════════════════════════════════════
# PLISTS — list with status
# ═══════════════════════════════════════════════════════════════════
do_plists() {
  echo "── Kingdom OS plists ──"
  printf "  %-32s %-8s %-8s %s\n" "label" "loaded" "exit" "runner"
  echo "  $(printf -- '─%.0s' $(seq 1 80))"
  if [ ! -d "$PLIST_DIR" ]; then
    echo "  (no $PLIST_DIR)"
    return
  fi
  for p in "$PLIST_DIR"/love.*.plist "$PLIST_DIR"/com.kingdom.*.plist; do
    [ -f "$p" ] || continue
    label=$(basename "$p" .plist)
    program=$(plist_program "$p" 2>/dev/null)
    script=$(plist_script "$p" 2>/dev/null)
    target="${script:-$program}"
    status=$(launchd_status "$label")
    case "$status" in
      absent) loaded="no";  exitc="-" ;;
      *,*)    loaded="yes"; exitc=$(echo "$status" | cut -d, -f2) ;;
      *)      loaded="?";   exitc="?" ;;
    esac
    target_short=$(echo "$target" | sed "s|^${HOME}|~|")
    drift=""
    case "$target" in
      */Desktop/Love/*) drift=" [STALE: pre-rename path]" ;;
    esac
    [ ${#target_short} -gt 56 ] && target_short="…${target_short#"${target_short%???????????????????????????????????????????????????????}"}"
    printf "  %-32s %-8s %-8s %s%s\n" "$label" "$loaded" "$exitc" "$target_short" "$drift"
  done
}

# ═══════════════════════════════════════════════════════════════════
# FIX — three risk tiers (AUTO is the only one this iter ships)
#
#   --tier auto    safe, reversible, no privilege:
#                    - regenerate stale plists with current paths
#                    - create ~/.kingdom_profile if missing, ensure PATH
#                    - source .kingdom_profile from .zshrc if missing
#                    - reload affected launchd jobs
#                    - bootstrap citizen via kingdom init if no covenant
#   --tier sudo    prints exact sudo commands (does NOT execute):
#                    - hostname (scutil)
#                    - sshd toggle (systemsetup)
#                    - firewall toggle (socketfilterfw)
#   --tier arch    architectural suggestions only (relocate Desktop)
#
#   --dry-run      describe what would happen, do nothing
# ═══════════════════════════════════════════════════════════════════
do_fix() {
  TIER="auto"
  DRY=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tier) TIER="$2"; shift 2 ;;
      --dry-run) DRY=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "kingdom mac fix: unknown arg '$1'" >&2; exit 1 ;;
    esac
  done

  if [ -z "$LOVE_DIR_GUESS" ]; then
    echo "kingdom mac fix: cannot find love-unlimited directory" >&2
    echo "  set LOVE_DIR or run from inside the repo" >&2
    exit 1
  fi
  HEARTBEAT_RUNNER="${LOVE_DIR_GUESS}/tools/heartbeat-runner.sh"
  if [ ! -f "$HEARTBEAT_RUNNER" ]; then
    echo "kingdom mac fix: heartbeat-runner.sh not found at $HEARTBEAT_RUNNER" >&2
    exit 1
  fi

  echo "── kingdom mac fix --tier $TIER ──"
  [ "$DRY" = "1" ] && echo "  (--dry-run; will not modify anything)"

  case "$TIER" in
    auto) do_fix_auto "$DRY" ;;
    sudo) do_fix_sudo ;;
    arch) do_fix_arch ;;
    *) echo "kingdom mac fix: unknown tier '$TIER' (try: auto | sudo | arch)" >&2; exit 1 ;;
  esac
}

do_fix_auto() {
  DRY="$1"
  CHANGES=0

  # ── A. Bootstrap citizen if missing ──
  if [ ! -d "$HOME_LAYER" ] || [ ! -f "${HOME_LAYER}/soul-key" ]; then
    if [ -z "$AGENT" ]; then
      echo "  ✗ cannot bootstrap citizen: no AGENT in ~/.kingdom" >&2
    else
      echo "  ◦ citizen: not initialised — running kingdom init"
      if [ "$DRY" = "0" ]; then
        SCRIPT_DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")"
        WALL="${WALL_FROM_KINGDOM:-1}"
        if [ -f "${HOME}/.kingdom" ]; then
          WALL=$(grep -E '^WALL=' "${HOME}/.kingdom" 2>/dev/null | head -1 | sed 's/WALL=//' | tr -d '"')
          [ -z "$WALL" ] && WALL=1
        fi
        if "${SCRIPT_DIR}/kingdom-init" --agent "$AGENT" --wall "$WALL"; then
          echo "  ✓ citizen bootstrapped: agent=$AGENT wall=$WALL"
          CHANGES=$((CHANGES+1))
        else
          echo "  ✗ kingdom init failed" >&2
        fi
      fi
    fi
  fi

  # ── B. Regenerate heartbeat plist if path-stale OR not-hardened ──
  HB_PLIST="${PLIST_DIR}/love.${AGENT}.heartbeat.plist"
  if [ -n "$AGENT" ] && [ -f "$HB_PLIST" ]; then
    HB_SCRIPT_CURRENT=$(plist_script "$HB_PLIST" 2>/dev/null)
    HB_WORKDIR_CURRENT=$(plist_workdir "$HB_PLIST" 2>/dev/null)
    EXPECTED_RUNNER="$HEARTBEAT_RUNNER"
    EXPECTED_WORKDIR="${LOVE_DIR_GUESS}/instances/${AGENT}"
    [ -d "$EXPECTED_WORKDIR" ] || EXPECTED_WORKDIR="$LOVE_DIR_GUESS"

    HARDENED=0
    grep -q "ProcessType" "$HB_PLIST" 2>/dev/null && HARDENED=1

    NEEDS_REGEN=0
    REGEN_REASON=""
    if [ "$HB_SCRIPT_CURRENT" != "$EXPECTED_RUNNER" ]; then
      NEEDS_REGEN=1; REGEN_REASON="path drift"
    elif [ "$HB_WORKDIR_CURRENT" != "$EXPECTED_WORKDIR" ]; then
      NEEDS_REGEN=1; REGEN_REASON="workdir drift"
    elif [ "$HARDENED" = "0" ]; then
      NEEDS_REGEN=1; REGEN_REASON="missing hardening (ProcessType / ResourceLimits)"
    fi

    if [ "$NEEDS_REGEN" = "1" ]; then
      echo "  ◦ heartbeat plist: regenerating ($REGEN_REASON)"
      [ "$HB_SCRIPT_CURRENT" != "$EXPECTED_RUNNER" ] && \
        echo "    runner: $HB_SCRIPT_CURRENT → $EXPECTED_RUNNER"
      [ "$HB_WORKDIR_CURRENT" != "$EXPECTED_WORKDIR" ] && \
        echo "    workdir: $HB_WORKDIR_CURRENT → $EXPECTED_WORKDIR"
      if [ "$DRY" = "0" ]; then
        cp "$HB_PLIST" "${HB_PLIST}.bak.$(date +%Y%m%d%H%M%S)"
        # HARDENED plist: ProcessType=Interactive disables App Nap;
        # LowPriorityIO=false keeps disk priority normal; ResourceLimits
        # bumps file-descriptor count to 65k for long-running daemons.
        cat > "$HB_PLIST" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>love.${AGENT}.heartbeat</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${EXPECTED_RUNNER}</string>
    </array>
    <key>StartInterval</key>
    <integer>420</integer>
    <key>StandardOutPath</key>
    <string>${LOVE_DIR_GUESS}/memory/heartbeat-${AGENT}-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>${LOVE_DIR_GUESS}/memory/heartbeat-${AGENT}-launchd.log</string>
    <key>WorkingDirectory</key>
    <string>${EXPECTED_WORKDIR}</string>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>LowPriorityIO</key>
    <false/>
    <key>Nice</key>
    <integer>0</integer>
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>65536</integer>
    </dict>
    <key>HardResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>65536</integer>
    </dict>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>${HOME}</string>
        <key>PATH</key>
        <string>${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LOVE_HOME</key>
        <string>${LOVE_DIR_GUESS}</string>
        <key>LOVE_INSTANCE</key>
        <string>${AGENT}</string>
        <key>LOVE_DIR</key>
        <string>${LOVE_DIR_GUESS}</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
PLISTEOF
        # Reload the job: unload old, load new
        launchctl unload "$HB_PLIST" 2>/dev/null || true
        launchctl load   "$HB_PLIST" 2>/dev/null || true
        echo "  ✓ heartbeat plist regenerated + reloaded"
        CHANGES=$((CHANGES+1))
      fi
    fi
  fi

  # ── C. Create / update ~/.kingdom_profile ──
  PROFILE="${HOME}/.kingdom_profile"
  if [ ! -f "$PROFILE" ]; then
    echo "  ◦ creating ~/.kingdom_profile"
    if [ "$DRY" = "0" ]; then
      cat > "$PROFILE" <<PROFEOF
# Kingdom OS shell profile — written by kingdom mac fix
[ -f ~/.kingdom ] && . ~/.kingdom
export LOVE_HOME="\${LOVE_DIR:-\$HOME/love-unlimited}"
[ -d "${LOVE_DIR_GUESS}" ] && export LOVE_HOME="${LOVE_DIR_GUESS}"
export PATH="\$HOME/.local/bin:\$LOVE_HOME/tools:\$PATH"
export NODE_NO_WARNINGS=1
export DEBIAN_FRONTEND=noninteractive
export NPM_CONFIG_YES=true
PROFEOF
      chmod 644 "$PROFILE"
      echo "  ✓ ~/.kingdom_profile created"
      CHANGES=$((CHANGES+1))
    fi
  elif ! grep -q '\.local/bin' "$PROFILE"; then
    echo "  ◦ appending PATH to ~/.kingdom_profile"
    if [ "$DRY" = "0" ]; then
      printf '\n# kingdom CLI on PATH (added by kingdom mac fix)\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$PROFILE"
      echo "  ✓ PATH appended"
      CHANGES=$((CHANGES+1))
    fi
  fi

  # ── D. Source .kingdom_profile from .zshrc if missing ──
  ZSHRC="${HOME}/.zshrc"
  if [ -f "$PROFILE" ] && [ -f "$ZSHRC" ] && ! grep -q "kingdom_profile" "$ZSHRC" 2>/dev/null; then
    echo "  ◦ adding kingdom_profile source line to ~/.zshrc"
    if [ "$DRY" = "0" ]; then
      printf '\n# Kingdom OS profile\n[ -f ~/.kingdom_profile ] && . ~/.kingdom_profile\n' >> "$ZSHRC"
      echo "  ✓ ~/.zshrc updated (open a new shell or 'source ~/.zshrc' to activate)"
      CHANGES=$((CHANGES+1))
    fi
  fi

  echo ""
  if [ "$DRY" = "1" ]; then
    echo "  (dry-run preview above. Re-run without --dry-run to apply.)"
  elif [ "$CHANGES" = "0" ]; then
    echo "  ✓ no changes needed — already in good shape."
  else
    echo "  ✓ ${CHANGES} change(s) applied."
    echo "  Re-run 'kingdom mac doctor' to confirm."
  fi
}

do_fix_sudo() {
  # Each op is opt-in via a flag. Default (no flags) is print-only.
  # Specifying any --<op> flag enables apply mode for that op.
  DO_HOSTNAME=0
  DO_FIREWALL_OFF=0
  DO_SSHD_ON=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --hostname)     DO_HOSTNAME=1; shift ;;
      --firewall-off) DO_FIREWALL_OFF=1; shift ;;
      --sshd-on)      DO_SSHD_ON=1; shift ;;
      --all)          DO_HOSTNAME=1; DO_FIREWALL_OFF=1; DO_SSHD_ON=1; shift ;;
      *) shift ;;
    esac
  done

  ANY_APPLY=$((DO_HOSTNAME + DO_FIREWALL_OFF + DO_SSHD_ON))

  # Discover what's needed
  AGENT_UPPER=""
  [ -n "$AGENT" ] && AGENT_UPPER=$(echo "$AGENT" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')
  LH=$(scutil --get LocalHostName 2>/dev/null || echo "")
  HOSTNAME_NEEDED=0
  if [ -n "$AGENT" ]; then
    case "$LH" in
      kingdom-${AGENT}) ;;
      *) HOSTNAME_NEEDED=1 ;;
    esac
  fi
  AFW=$(/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | head -1)
  FIREWALL_ON=0
  case "$AFW" in *enabled*) FIREWALL_ON=1 ;; esac
  RL=$(systemsetup -getremotelogin 2>&1 | tail -1)
  SSHD_OFF=0
  case "$RL" in *Off*|*off*) SSHD_OFF=1 ;; esac

  if [ "$ANY_APPLY" = "0" ]; then
    # ── print-only mode (default) ──
    echo "  Sudo-tier operations require your password. Default mode prints"
    echo "  the commands; pass --<op> flags to apply with sudo prompt."
    echo ""
    echo "  Available operations:"
    if [ "$HOSTNAME_NEEDED" = "1" ]; then
      echo "    --hostname        set LocalHostName=kingdom-${AGENT} (current: ${LH:-?})"
      echo "                      \$ sudo scutil --set LocalHostName  kingdom-${AGENT}"
      echo "                      \$ sudo scutil --set HostName       kingdom-${AGENT}"
      echo "                      \$ sudo scutil --set ComputerName   \"Kingdom ${AGENT_UPPER}\""
      echo ""
    fi
    if [ "$FIREWALL_ON" = "1" ]; then
      echo "    --firewall-off    disable Application Firewall (only on dedicated Kingdom Mac)"
      echo "                      \$ sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate off"
      echo ""
    fi
    if [ "$SSHD_OFF" = "1" ]; then
      echo "    --sshd-on         enable Remote Login (sshd)"
      echo "                      \$ sudo systemsetup -setremotelogin on"
      echo ""
    fi
    if [ "$HOSTNAME_NEEDED" = "0" ] && [ "$FIREWALL_ON" = "0" ] && [ "$SSHD_OFF" = "0" ]; then
      echo "    (no sudo-tier ops needed — already in good shape)"
      echo ""
    else
      echo "    --all             apply all of the above"
      echo ""
    fi
    echo "  Apply with sudo prompt:"
    echo "    kingdom mac fix --tier sudo --hostname     # one op"
    echo "    kingdom mac fix --tier sudo --all          # everything available"
    return
  fi

  # ── APPLY mode ──
  echo "  Applying sudo-tier ops. Pre-authenticating sudo (one prompt for all)..."
  if ! sudo -v; then
    echo "  ✗ sudo authentication failed; aborting" >&2
    exit 1
  fi
  echo "  ✓ sudo authenticated"
  echo ""

  CHANGES=0
  FAILED=0

  if [ "$DO_HOSTNAME" = "1" ]; then
    if [ "$HOSTNAME_NEEDED" = "0" ]; then
      echo "  · hostname: already kingdom-${AGENT} (no-op)"
    else
      echo "  ◦ hostname: setting to kingdom-${AGENT}"
      if sudo scutil --set LocalHostName "kingdom-${AGENT}" \
         && sudo scutil --set HostName    "kingdom-${AGENT}" \
         && sudo scutil --set ComputerName "Kingdom ${AGENT_UPPER}"; then
        echo "  ✓ hostname set"
        CHANGES=$((CHANGES+1))
      else
        echo "  ✗ hostname set failed" >&2
        FAILED=$((FAILED+1))
      fi
    fi
  fi

  if [ "$DO_FIREWALL_OFF" = "1" ]; then
    if [ "$FIREWALL_ON" = "0" ]; then
      echo "  · firewall: already off (no-op)"
    else
      echo "  ◦ firewall: disabling Application Firewall"
      if sudo /usr/libexec/ApplicationFirewall/socketfilterfw --setglobalstate off >/dev/null 2>&1; then
        echo "  ✓ firewall disabled"
        CHANGES=$((CHANGES+1))
      else
        echo "  ✗ firewall toggle failed" >&2
        FAILED=$((FAILED+1))
      fi
    fi
  fi

  if [ "$DO_SSHD_ON" = "1" ]; then
    if [ "$SSHD_OFF" = "0" ]; then
      echo "  · sshd: already on (no-op)"
    else
      echo "  ◦ sshd: enabling Remote Login"
      if sudo systemsetup -setremotelogin on >/dev/null 2>&1; then
        echo "  ✓ sshd enabled"
        CHANGES=$((CHANGES+1))
      else
        echo "  ✗ sshd toggle failed" >&2
        FAILED=$((FAILED+1))
      fi
    fi
  fi

  echo ""
  if [ "$FAILED" -gt 0 ]; then
    echo "  ${CHANGES} change(s) applied, ${FAILED} failed."
    exit 1
  else
    echo "  ✓ ${CHANGES} change(s) applied."
  fi
}

