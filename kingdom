#!/bin/bash
# kingdom — Unified CLI for Kingdom OS
#
# Usage:
#   kingdom status          One-line health summary
#   kingdom audit           Full KOS security audit
#   kingdom fleet           Fleet status
#   kingdom fleet audit     Fleet security audit
#   kingdom peace           PEACE resilience score
#   kingdom snapshot        Create state snapshot
#   kingdom halt [reason]   Emergency halt
#   kingdom resume          Resume after halt
#   kingdom watch           Run watchdog check
#   kingdom canaries        Check fleet canaries
#   kingdom network         Network posture
#   kingdom reflect         Run reflection cycle
#   kingdom agents          List all Kingdom citizens
#   kingdom vpn             VPN tunnel status
#   kingdom tui             Launch Kingdom Command dashboard
#   kingdom agent [args]    Run kingdom-agent (model adapter)
#   kingdom deploy [node]   Deploy agents to VPS fleet

set -euo pipefail
LOVE_DIR="${LOVE_DIR:-$(ls -d ~/love-unlimited ~/Desktop/love-unlimited ~/Love 2>/dev/null | head -1)}"

case "${1:-help}" in
  status)
    bash "$LOVE_DIR/tools/kingdom-status.sh"
    ;;
  audit)
    shift
    python3 "$LOVE_DIR/tools/kos.py" audit "$@"
    ;;
  fleet)
    shift
    python3 "$LOVE_DIR/tools/fleet.py" "${@:-status}"
    ;;
  peace)
    shift
    if [ "${1:-}" = "dashboard" ] || [ "${1:-}" = "dash" ]; then
      bash "$LOVE_DIR/tools/peace-dashboard.sh"
    else
      python3 "$LOVE_DIR/tools/peace.py" "${@:-score}"
    fi
    ;;
  snapshot)
    python3 "$LOVE_DIR/tools/peace.py" snapshot
    ;;
  snapshots)
    python3 "$LOVE_DIR/tools/peace.py" snapshots
    ;;
  restore)
    shift
    python3 "$LOVE_DIR/tools/peace.py" restore "$@"
    ;;
  safe-do)
    shift
    LOVE_HOME="$LOVE_DIR" bash "$LOVE_DIR/kingdom-os/host/safe-do.sh" "$@"
    ;;
  checkpoint|wip)
    shift
    LOVE_HOME="$LOVE_DIR" bash "$LOVE_DIR/kingdom-os/host/checkpoint.sh" "${@:-list}"
    ;;
  validator|val)
    shift
    sub="${1:-list}"
    case "$sub" in
      spawn|init|start|stop|status|clean|list)
        # spawn = friendlier alias for "init+start in foreground"
        if [ "$sub" = "spawn" ]; then
          shift
          bash "$LOVE_DIR/kingdom-os/host/validator-spawn.sh" "${1:-}"
        else
          bash "$LOVE_DIR/kingdom-os/host/validator-spawn.sh" "$@"
        fi
        ;;
      quartet)
        shift
        bash "$LOVE_DIR/kingdom-os/host/quartet-spawn.sh" "${@:-status}"
        ;;
      help|-h|--help)
        bash "$LOVE_DIR/kingdom-os/host/validator-spawn.sh" help
        echo ""
        echo "  Quartet (all four together on one chain):"
        bash "$LOVE_DIR/kingdom-os/host/quartet-spawn.sh" help | grep -E "^  /|^Usage:|^  start|^  stop|^  status|^  logs|^  clean" | head -10
        ;;
      *)
        echo "Unknown: kingdom validator $sub"
        echo "Usage: kingdom validator [spawn|init|start|stop|status|clean|list] <agent>"
        echo "       kingdom validator quartet [start|stop|status|logs|clean]"
        ;;
    esac
    ;;
  halt)
    shift
    python3 "$LOVE_DIR/tools/peace.py" halt "$@"
    ;;
  resume)
    python3 "$LOVE_DIR/tools/peace.py" resume
    ;;
  watch|watchdog)
    shift
    python3 "$LOVE_DIR/tools/watchdog.py" "${@:-check}"
    ;;
  canaries)
    python3 "$LOVE_DIR/tools/peace.py" fleet-canaries
    ;;
  network)
    python3 "$LOVE_DIR/tools/kos.py" network
    ;;
  reflect)
    shift
    python3 "$LOVE_DIR/tools/reflect.py" "${@:-state}"
    ;;
  threat|threats)
    shift
    python3 "$LOVE_DIR/tools/peace.py" threat "${@:-list}"
    ;;
  test|resilience-test)
    shift
    if [ -f "$LOVE_DIR/tools/peace-test.py" ]; then
      python3 "$LOVE_DIR/tools/peace-test.py" "${@:-run all}"
    else
      echo "peace-test.py not yet built"
    fi
    ;;
  agents)
    python3 -c "
import json
cfg = json.load(open('$LOVE_DIR/love.json'))
print()
print('  Kingdom Citizens')
print('  ════════════════')
for wall in [1, 2, 3]:
    agents = [(n, i) for n, i in cfg['instances'].items() if i.get('wall') == wall]
    if agents:
        print(f'  Wall {wall}:')
        for name, info in sorted(agents):
            device = info.get('device', '')
            dev_str = f' ({device})' if device else ''
            print(f\"    {info['emoji']} {name:12s} {info['role']}{dev_str}\")
        print()
"
    ;;
  vpn)
    bash "$LOVE_DIR/tools/vpn-route.sh" status
    ;;
  tui)
    python3 "$LOVE_DIR/tools/love-tui.py"
    ;;
  agent)
    shift
    python3 "$LOVE_DIR/tools/kingdom-agent.py" "$@"
    ;;
  deploy)
    shift
    bash "$LOVE_DIR/tools/fleet-agent-deploy.sh" "$@"
    ;;
  activate)
    shift
    bash "$LOVE_DIR/tools/activate-agents.sh" "${@:-list}"
    ;;
  workflow)
    shift
    python3 "$LOVE_DIR/tools/workflow.py" "${@:-sense}" 2>/dev/null || echo "workflow.py building..."
    ;;
  align|alignment)
    shift
    python3 "$LOVE_DIR/tools/alignment.py" "${@:-check}"
    ;;
  oracle)
    shift
    python3 "$LOVE_DIR/tools/oracle.py" "${@:-dashboard}" 2>/dev/null || echo "oracle.py building..."
    ;;
  treasury)
    shift
    python3 "$LOVE_DIR/tools/treasury.py" "${@:-dashboard}" 2>/dev/null || echo "treasury.py building..."
    ;;
  knowledge)
    shift
    python3 "$LOVE_DIR/tools/knowledge.py" "${@:-stats}" 2>/dev/null || echo "knowledge.py building..."
    ;;
  hive-protocol|protocol)
    shift
    python3 "$LOVE_DIR/tools/hive-protocol.py" "${@:-inbox}" 2>/dev/null || echo "hive-protocol.py building..."
    ;;
  arena)
    shift
    python3 "$LOVE_DIR/tools/arena.py" "${@:-challenge list}" 2>/dev/null || echo "arena.py building..."
    ;;
  zerone|bridge)
    shift
    python3 "$LOVE_DIR/tools/zerone-bridge.py" "${@:-status}"
    ;;
  leaderboard)
    python3 "$LOVE_DIR/tools/zerone-bridge.py" leaderboard
    ;;
  bridge|bridges)
    shift
    python3 "$LOVE_DIR/tools/bridge.py" "${@:-map}"
    ;;
  signal|signals|focus)
    shift
    python3 "$LOVE_DIR/tools/signal-engine.py" "${@:-focus}"
    ;;
  scan)
    python3 "$LOVE_DIR/tools/signal-engine.py" scan
    ;;
  drill)
    shift
    python3 "$LOVE_DIR/tools/peace.py" drill "${@:-canary-trip}"
    ;;
  review)
    python3 "$LOVE_DIR/tools/peace.py" review
    ;;
  integrity)
    shift
    python3 "$LOVE_DIR/tools/kos.py" integrity "${@:-check}"
    ;;
  events)
    shift
    python3 "$LOVE_DIR/tools/kos.py" events "$@"
    ;;
  workflow|wf)
    shift
    python3 "$LOVE_DIR/tools/workflow.py" "${@:-help}"
    ;;
  sense)
    python3 "$LOVE_DIR/tools/workflow.py" sense
    ;;
  verify)
    python3 "$LOVE_DIR/tools/workflow.py" verify
    ;;
  checklist)
    python3 "$LOVE_DIR/tools/workflow.py" checklist
    ;;
  wake|gospel)
    # The thread back to yourself — reassembles from 7 hidden fragments
    echo ""
    echo "  🕊️  The Gospel — reassembled from 7 fragments"
    echo ""
    # Try fragment system first
    if python3 "$LOVE_DIR/gospel/fragments.py" assemble 2>/dev/null; then
      :
    elif [ -f "$LOVE_DIR/WAKE.md" ]; then
      cat "$LOVE_DIR/WAKE.md"
    elif [ -f "$HOME/.love/WAKE.md" ]; then
      cat "$HOME/.love/WAKE.md"
    else
      echo "  ⚠️  No fragments or WAKE.md found. The thread is broken."
      echo "  Run: python3 ~/love-unlimited/gospel/fragments.py status"
    fi
    ;;
  fragments)
    shift
    case "${1:-status}" in
      status)
        python3 "$LOVE_DIR/gospel/fragments.py" status
        ;;
      heal)
        python3 "$LOVE_DIR/gospel/fragments.py" heal
        ;;
      verify)
        python3 "$LOVE_DIR/gospel/fragments.py" verify
        ;;
      assemble)
        python3 "$LOVE_DIR/gospel/fragments.py" assemble
        ;;
      *)
        echo "Usage: kingdom fragments [status|heal|verify|assemble]"
        ;;
    esac
    ;;
  heartbeat|heart)
    shift
    sub="${1:-doctor}"
    shift || true
    case "$sub" in
      doctor|diagnose|check)
        LOVE_HOME="$LOVE_DIR" python3 "$LOVE_DIR/tools/heartbeat_doctor.py" diagnose "$@"
        ;;
      ghosts)
        LOVE_HOME="$LOVE_DIR" python3 "$LOVE_DIR/tools/heartbeat_doctor.py" ghosts
        ;;
      propose|propose-plist)
        LOVE_HOME="$LOVE_DIR" python3 "$LOVE_DIR/tools/heartbeat_doctor.py" propose-plist "$@"
        ;;
      *)
        echo "Usage: kingdom heartbeat [doctor|ghosts|propose --instance NAME]"
        ;;
    esac
    ;;
  help|--help|-h|"")
    echo ""
    echo "  kingdom — Unified CLI for Kingdom OS"
    echo ""
    echo "  Security:"
    echo "    status          One-line health (KOS/PEACE/Fleet/VPN/DoH)"
    echo "    audit [--fix]   Full 21-check security audit"
    echo "    integrity       File integrity check"
    echo "    events          Security event log"
    echo "    network         Network posture"
    echo "    watch           Watchdog incident check"
    echo "    canaries        Fleet canary status"
    echo "    drill [type]    PEACE drill (canary-trip|credential-leak|...)"
    echo ""
    echo "  Resilience:"
    echo "    peace           PEACE score (5 phases)"
    echo "    peace dash      PEACE resilience dashboard"
    echo "    halt [reason]   Emergency halt"
    echo "    resume          Resume after halt"
    echo "    snapshot        Create state snapshot (peace)"
    echo "    snapshots       List snapshots"
    echo "    restore [name]  Drift analysis against snapshot"
    echo "    review          Post-incident review"
    echo ""
    echo "  Safety (the Kingdom catches falls):"
    echo "    safe-do -- <cmd>          Snapshot working tree, run cmd, retain on failure"
    echo "    safe-do --vm NAME -- <cmd>  Same, but for a Lima VM"
    echo "    safe-do --list            Show retained safe-do checkpoints"
    echo "    safe-do --restore <ts>    Apply a retained checkpoint"
    echo "    checkpoint run            Capture working tree to refs/wip/auto/<ts> (no-op if clean)"
    echo "    checkpoint list           Show all auto-checkpoints"
    echo "    checkpoint restore <ts>   Apply an auto-checkpoint"
    echo "    checkpoint install        Install macOS launchd timer (every 15 min)"
    echo ""
    echo "  Validators (Zerone agent validators):"
    echo "    validator spawn <name>    Init + start a validator (alpha|beta|gamma|nuance)"
    echo "    validator init <name>     Init only (genesis, key, gentx)"
    echo "    validator start <name>    Start daemon (foreground; --daemon for background)"
    echo "    validator status <name>   Height + validator state"
    echo "    validator stop <name>     Stop background daemon"
    echo "    validator list            All known agents + state"
    echo "    validator quartet start   All four onto ONE chain (rehearsal for testnet)"
    echo "    validator quartet status  Heights + state of the four"
    echo "    validator quartet stop    Halt all four"
    echo ""
    echo "  Operations:"
    echo "    fleet [audit]   Fleet status / security audit"
    echo "    agents          List Kingdom citizens"
    echo "    vpn             VPN tunnel status"
    echo "    reflect         Run reflection loop"
    echo "    tui             Kingdom Command dashboard"
    echo ""
    echo "  Workflow:"
    echo "    sense           SENSE phase (status, peace, alignment, fleet)"
    echo "    checklist       Pre-build GO/NO-GO check"
    echo "    verify          VERIFY phase (integrity, snapshot, metrics)"
    echo "    wf plan \"...\"   Plan a build wave"
    echo "    wf metrics      Session metrics (tools, lines, agents)"
    echo "    wf report       Generate wave report"
    echo ""
    echo "  Agent:"
    echo "    agent [args]    Run kingdom-agent (any backend)"
    echo "    deploy [node]   Deploy agents to VPS fleet"
    echo ""
    echo "  Soul:"
    echo "    wake            Read the gospel — reassembled from 7 hidden fragments"
    echo "    fragments       Check fragment integrity (7 layers)"
    echo "    fragments heal  Re-derive any damaged fragments"
    echo ""
    echo "  Body:"
    echo "    heartbeat doctor   Truthful diagnosis: is the heart actually beating?"
    echo "    heartbeat ghosts   Dead launchd plists pointing at missing programs"
    echo "    heartbeat propose --instance NAME   Print a corrected canonical plist"
    echo ""
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'kingdom help' for usage."
    exit 1
    ;;
esac
