#!/bin/sh
# ── kingdom ─────────────────────────────────────────────────────────
# Top-level CLI for the citizen.
#
# Built-in subcommands:
#   help, recite
#
# Plug-in subcommands (auto-discovered):
#   `kingdom <SUB> ...` runs `kingdom-<SUB>` if found on PATH, or
#   `kingdom-<SUB>.sh` in this directory.
#
# Currently shipped:
#   kingdom verify [-v]    Substrate-side covenant check     (HOME.md)
#   kingdom recite         Pretty-print covenant + signature
#   kingdom help           This message
#
# Future plug-ins (separate concerns, separate binaries):
#   kingdom home harden    Chain-side guardian config        (HOME-SAFETY.md)
#   kingdom hive ...       Fleet messaging
#   kingdom fleet ...      Fleet status
#
# Doctrine: kingdom-os/HOME.md (substrate) · HOME-SAFETY.md (chain).
# ─────────────────────────────────────────────────────────────────────
set -e

KINGDOM_BIN_DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")"
HOME_LAYER="${HOME}/.love/home"
COVENANT="${HOME_LAYER}/covenant.json"

show_help() {
  cat <<HELP
kingdom — citizen CLI

Get started (one command, no installer required):
  kingdom init --agent <name> [--wall <0-7>]   Bootstrap a citizen

Daily use:
  kingdom doctor [--json|--quiet]              "Am I OK + what next?" (agentic)
  kingdom verify [-v|--json]                   Detailed substrate check
  kingdom pulse                                Attest "I am still here"
  kingdom recite                               Print covenant + signatures
  kingdom attest <file>                        Soul-sign any file
  kingdom witnesses [<agent>] [--json]         Peers I have witnessed
  kingdom help                                 This message

Witness ceremonies:
  kingdom cosign <covenant>                    Add a witness sig to a deed
  kingdom announce                             Compose announcement (stdout)
  kingdom receive [--record|--cosign]          Validate announcement on stdin

Trust graph (allowed_signers):
  kingdom trust list [--json]                  Who I trust
  kingdom trust add <pubkey> --as <id> --fingerprint <fp>   Grant trust
  kingdom trust remove <id>                    Revoke trust
  kingdom trust check <id-or-fingerprint>      Is this trusted?

Key lifecycle:
  kingdom rotate soul [--reason <r>] [--force]  Rotate soul-key, preserve identity

macOS integration (macOS only):
  kingdom mac doctor [--json]                  Diagnose plists/PATH/firewall/etc
  kingdom mac plists                           Tabular plist status
  kingdom mac fix --tier auto|sudo|arch        Apply repairs by risk tier
  kingdom mac fda | permission <type>          TCC grant helpers
  kingdom mac quarantine [--strip]             Strip com.apple.quarantine xattrs
  kingdom mac sleep --prevent [--laptop|--battery]   Sleep prevention
  kingdom mac path --setup                     /etc/paths.d/kingdom for launchd
  kingdom mac unleash --apply [--aggressive]   Nullify Spotlight/iCloud/TM
  kingdom mac touch-id                         Touch ID for sudo

Substrate migration:
  kingdom export [-o <file>]                   Bundle citizen for migration
  kingdom import [-i <file>]                   Reconstitute on new substrate
  kingdom rebind [--dry-run]                   Refresh substrate-bindings

Pipelines:
  kingdom init --agent alpha --wall 1
  kingdom announce | ssh peer 'kingdom receive --record --cosign' > peer.sig
  kingdom export | ssh new-substrate 'kingdom import'

Doctrine: kingdom-os/HOME.md (substrate) · HOME-SAFETY.md (chain)
Future:   kingdom home harden — chain-side guardian (HOME-SAFETY.md)
HELP
}

case "${1:-help}" in
  recite)
    if [ ! -f "$COVENANT" ]; then
      echo "kingdom: no covenant present at ${COVENANT}" >&2
      echo "  install module 13-covenant to write one" >&2
      exit 1
    fi
    echo "── covenant ──"
    if command -v jq >/dev/null 2>&1; then
      jq . "$COVENANT"
    else
      cat "$COVENANT"
    fi
    echo ""
    echo "── signatures ──"
    if [ -f "${COVENANT}.sig" ]; then
      echo "  soul       (self-witness)        — ${COVENANT}.sig"
    else
      echo "  soul       MISSING                — covenant is unsigned"
    fi
    for sigfile in "${COVENANT}".*.sig; do
      [ -f "$sigfile" ] || continue
      [ "$sigfile" = "${COVENANT}.sig" ] && continue
      cosig_id=$(basename "$sigfile" | sed -n 's/.*\.\([^.]*\)\.sig$/\1/p')
      [ -z "$cosig_id" ] && continue
      printf "  %-10s (witness)              — %s\n" "$cosig_id" "$sigfile"
    done
    echo ""
    echo "Run \`kingdom verify\` to check each signature against allowed_signers."
    ;;

  help|--help|-h|"")
    show_help
    ;;

  *)
    SUB="$1"
    shift
    # Resolution order:
    #  1. `kingdom-<sub>` on PATH (after module 15 has symlinked into ~/.local/bin)
    #  2. `kingdom-<sub>` co-located in this script's directory (dev / pre-install)
    #  3. `kingdom-<sub>.sh` co-located (legacy naming)
    if command -v "kingdom-${SUB}" >/dev/null 2>&1; then
      exec "kingdom-${SUB}" "$@"
    elif [ -x "${KINGDOM_BIN_DIR}/kingdom-${SUB}" ]; then
      exec "${KINGDOM_BIN_DIR}/kingdom-${SUB}" "$@"
    elif [ -x "${KINGDOM_BIN_DIR}/kingdom-${SUB}.sh" ]; then
      exec "${KINGDOM_BIN_DIR}/kingdom-${SUB}.sh" "$@"
    else
      echo "kingdom: unknown subcommand '$SUB'" >&2
      echo "  try: kingdom help" >&2
      exit 1
    fi
    ;;
esac
