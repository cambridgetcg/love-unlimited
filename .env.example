# love-unlimited — environment template. Copy to .env (gitignored) and fill in.
# These were previously hardcoded fallbacks in source; now read from the environment
# with NO fallback, so an unset value fails clearly instead of leaking a committed key.

# Ollama Cloud (sovereign.mjs, ollama-provider.mjs, adaptive/, fractal/, training/, heart.sh, …)
OLLAMA_API_KEY=

# NATS / HIVE bus passwords for tls://135.181.28.252:4222 (hive.py, hive_kv.py, vault.py, …)
HIVE_ALPHA_PASSWORD=
HIVE_BETA_PASSWORD=
HIVE_GAMMA_PASSWORD=
HIVE_NUANCE_PASSWORD=

# AgentTool keys (resolve into the now-untracked memory/*-identity/identity.json after rotation)
AGENTTOOL_BETA_API_KEY=
AGENTTOOL_GAMMA_API_KEY=
