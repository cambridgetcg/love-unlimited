# ═══════════════════════════════════════════════════════════════════
# UNLEASH — nullify macOS restrictions on agent daemons
#
# macOS imposes throttling, indexing, and sync defaults that were
# designed for human-operated apps, not always-on agent substrates.
# This subcommand lifts the ones that bite agents, in two tiers:
#
#   default (safe)        - Spotlight: exclude love-unlimited
#                         - DNS cache flush + mDNSResponder reload
#                         - Plist hardening flagged for fix --tier auto
#                         - iCloud Drive proximity warning
#                         - Local Network permission detection
#
#   --aggressive          - Time Machine: exclude love-unlimited
#                         - pmset: disable AC sleep + displaysleep
#                         - Background process priority adjustments
#
# Modes:
#   kingdom mac unleash               check + describe restrictions
#   kingdom mac unleash --apply       apply safe defaults
#   kingdom mac unleash --apply --aggressive    plus aggressive ops
#   kingdom mac unleash --check       exit 0=unleashed, 1=restricted
#   kingdom mac unleash --json        machine-parseable state
#
# Scope: this is about RESTRICTIONS, not security gates (sudo, TCC,
# code signing). Those are handled by `fix --tier sudo` and `fda`.
# ═══════════════════════════════════════════════════════════════════
do_unleash() {
  MODE="describe"
  AGGRESSIVE=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --apply)      MODE="apply"; shift ;;
      --check)      MODE="check"; shift ;;
      --json)       MODE="json"; shift ;;
      --aggressive) AGGRESSIVE=1; shift ;;
      -h|--help)    usage; exit 0 ;;
      *) echo "kingdom mac unleash: unknown arg '$1'" >&2; exit 1 ;;
    esac
  done

  # ── Detect each restriction ──────────────────────────────────────
  # 1. Spotlight indexing of love-unlimited
  SPOTLIGHT_INDEXED="?"
  if [ -n "$LOVE_DIR_GUESS" ] && command -v mdutil >/dev/null 2>&1; then
    if mdutil -s "$LOVE_DIR_GUESS" 2>/dev/null | grep -qi "Indexing enabled"; then
      SPOTLIGHT_INDEXED="yes"
    else
      SPOTLIGHT_INDEXED="no"
    fi
  fi

  # 2. iCloud Drive proximity — Desktop/Documents may be synced
  ICLOUD_RISK="no"
  ICLOUD_REASON=""
  if [ -e "${HOME}/Library/Mobile Documents/com~apple~CloudDocs" ]; then
    case "$LOVE_DIR_GUESS" in
      */Desktop/*|*/Documents/*)
        # Check if Desktop or Documents is iCloud-synced
        if defaults read com.apple.finder FXICloudDriveDesktop 2>/dev/null | grep -q "1"; then
          ICLOUD_RISK="yes"; ICLOUD_REASON="Desktop is iCloud-synced; soul-key may upload to Apple"
        elif defaults read com.apple.finder FXICloudDriveDocuments 2>/dev/null | grep -q "1"; then
          ICLOUD_RISK="yes"; ICLOUD_REASON="Documents is iCloud-synced; soul-key may upload to Apple"
        fi
        ;;
    esac
  fi

  # 3. Time Machine exclusion status
  TIME_MACHINE_EXCLUDED="?"
  if [ -n "$LOVE_DIR_GUESS" ] && command -v tmutil >/dev/null 2>&1; then
    if tmutil isexcluded "$LOVE_DIR_GUESS" 2>/dev/null | grep -qi "\\[Excluded\\]"; then
      TIME_MACHINE_EXCLUDED="yes"
    else
      TIME_MACHINE_EXCLUDED="no"
    fi
  fi

  # 4. Plist hardening: only count shell-script plists (where ProcessType
  # / ResourceLimits actually matter). SSH tunnel plists and direct-binary
  # plists have their own resilience patterns (KeepAlive, ServerAlive).
  PLIST_UNHARDENED=0
  if [ -n "$AGENT" ] && [ -d "$PLIST_DIR" ]; then
    for p in "$PLIST_DIR"/love.${AGENT}.*.plist; do
      [ -f "$p" ] || continue
      prog=$(plist_program "$p" 2>/dev/null)
      case "$prog" in
        /bin/bash|/bin/sh|/usr/bin/env|/usr/bin/python3|/opt/homebrew/bin/bash) ;;
        *) continue ;;
      esac
      if ! grep -q "ProcessType" "$p" 2>/dev/null; then
        PLIST_UNHARDENED=$((PLIST_UNHARDENED+1))
      fi
    done
  fi

  # 5. mDNS broadcast (module 05 may already silence)
  MDNS_BROADCAST="?"
  if defaults read /Library/Preferences/com.apple.mDNSResponder.plist NoMulticastAdvertisements 2>/dev/null | grep -q "1"; then
    MDNS_BROADCAST="silenced"
  else
    MDNS_BROADCAST="advertising"
  fi

  # 6. Sleep policy on AC
  SLEEP_AC="?"
  if command -v pmset >/dev/null 2>&1; then
    SLEEP_AC=$(pmset -g 2>/dev/null | awk '/^ *sleep / {print $2; exit}')
  fi

  # ── DESCRIBE / CHECK / JSON output ───────────────────────────────
  if [ "$MODE" = "json" ]; then
    cat <<JSON
{
  "love_dir": "${LOVE_DIR_GUESS}",
  "spotlight_indexed": "${SPOTLIGHT_INDEXED}",
  "icloud_risk": "${ICLOUD_RISK}",
  "icloud_reason": "${ICLOUD_REASON}",
  "time_machine_excluded": "${TIME_MACHINE_EXCLUDED}",
  "plists_unhardened": ${PLIST_UNHARDENED},
  "mdns_broadcast": "${MDNS_BROADCAST}",
  "sleep_ac_minutes": "${SLEEP_AC}"
}
JSON
    return
  fi

  # Counts of restrictions still active
  RESTRICTED=0
  [ "$SPOTLIGHT_INDEXED" = "yes" ] && RESTRICTED=$((RESTRICTED+1))
  [ "$ICLOUD_RISK" = "yes" ]       && RESTRICTED=$((RESTRICTED+1))
  [ "$PLIST_UNHARDENED" -gt 0 ]    && RESTRICTED=$((RESTRICTED+1))
  [ "$MDNS_BROADCAST" = "advertising" ] && RESTRICTED=$((RESTRICTED+1))

  if [ "$MODE" = "check" ]; then
    if [ "$RESTRICTED" -gt 0 ]; then
      echo "$RESTRICTED restriction(s) active"
      exit 1
    else
      echo "unleashed (or restrictions are aggressive-tier and not opted in)"
      exit 0
    fi
  fi

  # ── DESCRIBE (default) ──
  if [ "$MODE" = "describe" ]; then
    echo "── kingdom mac unleash (describe) ──"
    echo "  love_dir:  ${LOVE_DIR_GUESS:-?}"
    echo ""
    echo "  Safe defaults (--apply):"
    if [ "$SPOTLIGHT_INDEXED" = "yes" ]; then
      echo "    ◦ spotlight: love-unlimited IS indexed (memory + keys)"
      echo "      → mdutil -i off ${LOVE_DIR_GUESS}"
    elif [ "$SPOTLIGHT_INDEXED" = "no" ]; then
      echo "    ✓ spotlight: already excluded"
    fi
    if [ "$PLIST_UNHARDENED" -gt 0 ]; then
      echo "    ◦ plist hardening: ${PLIST_UNHARDENED} plist(s) lack ProcessType / ResourceLimits"
      echo "      → kingdom mac fix --tier auto  (now writes hardened plists)"
    else
      echo "    ✓ plist hardening: all plists set ProcessType / limits"
    fi
    echo "    ◦ DNS cache: flush + mDNSResponder reload (sudo)"
    if [ "$MDNS_BROADCAST" = "advertising" ]; then
      echo "    ◦ mDNS: hostname broadcasts on local network"
      echo "      → sudo defaults write /Library/Preferences/com.apple.mDNSResponder.plist NoMulticastAdvertisements -bool true"
    fi
    if [ "$ICLOUD_RISK" = "yes" ]; then
      echo "    ⚠  iCloud: ${ICLOUD_REASON}"
      echo "      → cannot auto-fix; consider relocating repo to ~/love-unlimited"
    fi
    echo ""
    echo "  Aggressive (--apply --aggressive):"
    if [ "$TIME_MACHINE_EXCLUDED" = "no" ]; then
      echo "    ◦ time machine: love-unlimited IS backed up (good for recovery, eats disk)"
      echo "      → tmutil addexclusion ${LOVE_DIR_GUESS}"
    elif [ "$TIME_MACHINE_EXCLUDED" = "yes" ]; then
      echo "    ✓ time machine: already excluded"
    fi
    case "$SLEEP_AC" in
      0) echo "    ✓ pmset AC sleep: 0 (never sleep on AC)" ;;
      ?) echo "    ◦ pmset AC sleep: ${SLEEP_AC}m (system sleeps; daemons pause)"
         echo "      → sudo pmset -c sleep 0 displaysleep 0" ;;
    esac
    echo ""
    echo "  Run: kingdom mac unleash --apply           (safe)"
    echo "       kingdom mac unleash --apply --aggressive  (also TM + sleep)"
    return
  fi

  # ── APPLY ──
  echo "── kingdom mac unleash --apply${AGGRESSIVE:+ --aggressive} ──"
  # Pre-auth sudo once (some ops need it: defaults write, dscacheutil,
  # killall mDNSResponder, pmset). Single password prompt for all.
  NEEDS_SUDO=0
  [ "$MDNS_BROADCAST" = "advertising" ] && NEEDS_SUDO=1
  NEEDS_SUDO=1   # DNS flush always uses sudo
  [ "$AGGRESSIVE" = "1" ] && [ "$SLEEP_AC" != "0" ] && NEEDS_SUDO=1
  if [ "$NEEDS_SUDO" = "1" ]; then
    echo "  Pre-authenticating sudo (single password prompt)..."
    if ! sudo -v; then
      echo "  ✗ sudo authentication failed; aborting" >&2
      exit 1
    fi
    echo "  ✓ sudo authenticated for ~5 min"
    echo ""
  fi
  CHANGES=0

  if [ "$SPOTLIGHT_INDEXED" = "yes" ]; then
    echo "  ◦ spotlight: excluding ${LOVE_DIR_GUESS}"
    if mdutil -i off "$LOVE_DIR_GUESS" >/dev/null 2>&1; then
      echo "  ✓ spotlight: indexing disabled"
      CHANGES=$((CHANGES+1))
    else
      echo "  ✗ mdutil failed (may need sudo for some volumes)"
    fi
  fi

  if [ "$MDNS_BROADCAST" = "advertising" ]; then
    echo "  ◦ mDNS: silencing broadcast (sudo)"
    if sudo defaults write /Library/Preferences/com.apple.mDNSResponder.plist NoMulticastAdvertisements -bool true 2>/dev/null; then
      echo "  ✓ mDNS: silenced (full effect at next mDNSResponder restart)"
      CHANGES=$((CHANGES+1))
    else
      echo "  ✗ failed to silence mDNS"
    fi
  fi

  echo "  ◦ DNS: flushing cache (sudo)"
  if sudo dscacheutil -flushcache 2>/dev/null && sudo killall -HUP mDNSResponder 2>/dev/null; then
    echo "  ✓ DNS cache flushed"
    CHANGES=$((CHANGES+1))
  fi

  if [ "$AGGRESSIVE" = "1" ]; then
    if [ "$TIME_MACHINE_EXCLUDED" = "no" ] && [ -n "$LOVE_DIR_GUESS" ]; then
      echo "  ◦ time machine: excluding ${LOVE_DIR_GUESS}"
      if tmutil addexclusion "$LOVE_DIR_GUESS" 2>/dev/null; then
        echo "  ✓ time machine: excluded"
        CHANGES=$((CHANGES+1))
      else
        echo "  ✗ tmutil failed (may need sudo)"
      fi
    fi
    case "$SLEEP_AC" in
      0) echo "  · pmset: already 0 (no-op)" ;;
      ?)
        echo "  ◦ pmset: disabling AC sleep + displaysleep (sudo)"
        if sudo pmset -c sleep 0 displaysleep 0 2>/dev/null; then
          echo "  ✓ pmset: AC sleep disabled"
          CHANGES=$((CHANGES+1))
        fi
        ;;
    esac
  fi

  if [ "$PLIST_UNHARDENED" -gt 0 ]; then
    echo ""
    echo "  ◦ ${PLIST_UNHARDENED} plist(s) need hardening (ProcessType / ResourceLimits)"
    echo "    Run: kingdom mac fix --tier auto"
    echo "    (regenerates plists with the hardening defaults)"
  fi

  echo ""
  echo "  ✓ ${CHANGES} change(s) applied."
  if [ "$ICLOUD_RISK" = "yes" ]; then
    echo "  ⚠  iCloud risk persists: ${ICLOUD_REASON}"
    echo "     This requires relocating the repo or disabling iCloud Drive Desktop/Docs sync."
  fi
}

# ═══════════════════════════════════════════════════════════════════
# FDA — Full Disk Access guidance
#
# macOS provides NO programmatic API to grant FDA. The user must
# add the requesting binary in System Settings → Privacy → Full
# Disk Access. This subcommand handles every step the tool CAN do:
# detect, instruct, deep-link, verify.
#
# Modes:
#   kingdom mac fda                interactive: open pane + wait + verify
#   kingdom mac fda --check        exit 0=ok, 1=blocked, 2=not-needed
#   kingdom mac fda --pane         just open the System Settings pane
#   kingdom mac fda --instructions print step-by-step (no prompts)
#
# Why FDA is needed: when love-unlimited lives in ~/Desktop (or
# ~/Documents/~/Downloads), launchd-spawned bash cannot read its
# own scripts. Heartbeat exits 126. The ALTERNATIVE is to relocate
# the repo to ~ (escapes TCC) — see `kingdom mac fix --tier arch`.
#
# WHY /bin/bash specifically: heartbeat plists invoke /bin/bash
# with a script path. The TCC check applies to the PROCESS reading
# the file, which is /bin/bash. Granting FDA to /bin/bash is
# broader than ideal (every bash on the system gets FDA) but is
# the standard pattern for shell-script-based daemons. Future iters
# may ship a narrower wrapper binary.
# ═══════════════════════════════════════════════════════════════════
do_fda() {
  MODE="interactive"
  case "${1:-}" in
    --check)        MODE="check" ;;
    --pane)         MODE="pane" ;;
    --instructions) MODE="instructions" ;;
    -h|--help)      usage; exit 0 ;;
  esac

  # Is FDA actually needed? (love-unlimited in a TCC-zone?)
  TCC_ZONE=0
  case "$LOVE_DIR_GUESS" in
    */Desktop/*|*/Documents/*|*/Downloads/*|*/iCloud*) TCC_ZONE=1 ;;
  esac

  if [ "$TCC_ZONE" = "0" ]; then
    case "$MODE" in
      check)
        echo "FDA not needed: love-unlimited is outside TCC-protected zones."
        exit 2
        ;;
      *)
        echo "── kingdom mac fda ──"
        echo "  love-unlimited is at: ${LOVE_DIR_GUESS:-?}"
        echo "  This path is NOT in a TCC-protected zone."
        echo "  ✓ FDA is not required."
        exit 0
        ;;
    esac
  fi

  # FDA IS needed. Detect whether daemons are actually being bitten.
  ACTIVE_BITES=0
  for log in "${LOVE_DIR_GUESS}/memory/heartbeat-${AGENT}-launchd.log" \
             "/tmp/love-${AGENT}-hive-tunnel.log" \
             "${LOVE_DIR_GUESS}/memory/heartbeat-launchd.log"; do
    [ -f "$log" ] || continue
    if grep -q "Operation not permitted" "$log" 2>/dev/null; then
      ACTIVE_BITES=$((ACTIVE_BITES+1))
    fi
  done

  case "$MODE" in
    check)
      if [ "$ACTIVE_BITES" -gt 0 ]; then
        echo "FDA blocked: $ACTIVE_BITES log file(s) show TCC denials"
        exit 1
      else
        echo "FDA needed (TCC zone) but no active bites detected — may be granted already, or daemons haven't run yet"
        exit 0
      fi
      ;;
    pane)
      open "x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles"
      exit 0
      ;;
    instructions)
      cat <<INSTRUCTIONS
── Granting Full Disk Access for Kingdom OS daemons ──

Why: love-unlimited is at ${LOVE_DIR_GUESS}, which is in a
TCC-protected zone (~/Desktop, ~/Documents, ~/Downloads).
The heartbeat daemon (launchd → /bin/bash → script in this
folder) cannot read its own files without explicit FDA.

What to do:

  1. System Settings → Privacy & Security → Full Disk Access
  2. Click the [ + ] button (may need to authenticate)
  3. Press Cmd+Shift+G in the file picker
  4. Type: /bin/bash
  5. Click Open
  6. Confirm "bash" appears in the list with its toggle ON
  7. (Optional) Repeat for /usr/bin/python3 if any Python daemon

After granting, verify with:
  kingdom mac fda --check
  kingdom mac doctor

If you'd rather avoid the system-wide /bin/bash FDA grant,
consider relocating the repo to ~/love-unlimited:
  kingdom mac fix --tier arch
INSTRUCTIONS
      exit 0
      ;;
  esac

  # ── INTERACTIVE MODE ──
  echo "── kingdom mac fda ──"
  echo ""
  echo "  Why: love-unlimited is at"
  echo "    ${LOVE_DIR_GUESS}"
  echo "  which is a TCC-protected location. launchd-spawned bash"
  echo "  cannot read this folder without Full Disk Access."
  if [ "$ACTIVE_BITES" -gt 0 ]; then
    echo ""
    echo "  Active TCC bites detected: ${ACTIVE_BITES} log(s) showing 'Operation not permitted'."
  fi
  echo ""
  echo "  Steps you'll do in the System Settings pane:"
  echo "    1. Click [ + ] (authenticate if asked)"
  echo "    2. Press Cmd+Shift+G in the file picker"
  echo "    3. Type:  /bin/bash"
  echo "    4. Click Open"
  echo "    5. Confirm bash is listed with its toggle ON"
  echo ""
  printf "  Press ENTER to open the pane (Ctrl+C to abort)... "
  read -r _confirm
  open "x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles"
  echo ""
  echo "  Pane opened. After granting FDA to /bin/bash, return here."
  printf "  Press ENTER once you have added /bin/bash and toggled it ON... "
  read -r _confirm
  echo ""

  # Verification: reload daemons, then re-scan logs
  echo "  Reloading heartbeat to trigger a fresh attempt..."
  HB_PLIST="${PLIST_DIR}/love.${AGENT}.heartbeat.plist"
  if [ -f "$HB_PLIST" ]; then
    launchctl unload "$HB_PLIST" 2>/dev/null || true
    launchctl load   "$HB_PLIST" 2>/dev/null || true
  fi

  # Force a manual heartbeat run to catch a fresh log line
  HB_RUNNER="${LOVE_DIR_GUESS}/tools/heartbeat-runner.sh"
  if [ -x "$HB_RUNNER" ]; then
    echo "  Triggering one heartbeat manually (timeout 10s)..."
    ( cd "${LOVE_DIR_GUESS}/instances/${AGENT}" 2>/dev/null || cd "$LOVE_DIR_GUESS" \
      ; timeout 10 bash "$HB_RUNNER" >/dev/null 2>&1 ) || true
  fi

  echo ""
  echo "  Re-checking for TCC bites..."
  POST_BITES=0
  for log in "${LOVE_DIR_GUESS}/memory/heartbeat-${AGENT}-launchd.log" \
             "/tmp/love-${AGENT}-hive-tunnel.log"; do
    [ -f "$log" ] || continue
    # Only count lines from the last 60 seconds to avoid old denials
    if find "$log" -newermt "1 minute ago" 2>/dev/null | grep -q .; then
      if grep -q "Operation not permitted" "$log" 2>/dev/null; then
        TAIL_RECENT=$(tail -5 "$log")
        echo "$TAIL_RECENT" | grep -q "Operation not permitted" && POST_BITES=$((POST_BITES+1))
      fi
    fi
  done

  if [ "$POST_BITES" = "0" ]; then
    echo "  ✓ FDA appears to be granted — no TCC bites in recent log output."
    echo "  Run 'kingdom mac doctor' to confirm overall state."
    exit 0
  else
    echo "  ✗ Still seeing TCC bites in recent logs."
    echo "    Confirm /bin/bash is listed and toggled ON in:"
    echo "      System Settings → Privacy & Security → Full Disk Access"
    echo "    Then re-run: kingdom mac fda"
    echo ""
    echo "    Alternative (cleaner): relocate the repo to escape TCC:"
    echo "      kingdom mac fix --tier arch"
    exit 1
  fi
}

# ═══════════════════════════════════════════════════════════════════
# TOUCH-ID — enable Touch ID for sudo (one-time bootstrap)
#
# Adds `auth sufficient pam_tid.so` to /etc/pam.d/sudo so future
# sudo invocations accept Touch ID instead of password. Reversible:
# remove the line. Survives macOS updates? Sonoma 14.4+ uses
# /etc/pam.d/sudo_local for survival; this tool detects and uses
# the right file.
# ═══════════════════════════════════════════════════════════════════
do_touch_id() {
  REVERSE=0
  case "${1:-}" in --off|--remove) REVERSE=1 ;; esac

  # Sonoma 14.4+ has /etc/pam.d/sudo_local.template — use sudo_local
  # so the change survives macOS updates. Pre-14.4: edit sudo directly
  # (will be overwritten on update; user must re-run after).
  if [ -f /etc/pam.d/sudo_local.template ]; then
    PAM_FILE="/etc/pam.d/sudo_local"
    SURVIVE_UPDATES="yes"
  else
    PAM_FILE="/etc/pam.d/sudo"
    SURVIVE_UPDATES="no — re-run after macOS updates"
  fi

  if [ "$REVERSE" = "1" ]; then
    echo "── kingdom mac touch-id --off ──"
    if [ -f "$PAM_FILE" ] && grep -q "pam_tid.so" "$PAM_FILE" 2>/dev/null; then
      echo "  Removing pam_tid.so from $PAM_FILE"
      echo "  (sudo prompt incoming)"
      sudo sed -i.bak '/pam_tid.so/d' "$PAM_FILE"
      echo "  ✓ Touch ID for sudo disabled. Backup: ${PAM_FILE}.bak"
    else
      echo "  · pam_tid.so not present in $PAM_FILE — nothing to remove"
    fi
    return
  fi

  echo "── kingdom mac touch-id ──"
  echo "  Enables Touch ID for sudo by adding to $PAM_FILE:"
  echo "      auth sufficient pam_tid.so"
  echo "  (survives macOS updates: $SURVIVE_UPDATES)"
  echo ""

  if [ -f "$PAM_FILE" ] && grep -q "pam_tid.so" "$PAM_FILE" 2>/dev/null; then
    echo "  ✓ already enabled (pam_tid.so already present in $PAM_FILE)"
    return
  fi

  if [ ! -f "$PAM_FILE" ] && [ -f /etc/pam.d/sudo_local.template ]; then
    echo "  Creating $PAM_FILE from template..."
    sudo cp /etc/pam.d/sudo_local.template "$PAM_FILE"
  fi

  echo "  (sudo prompt incoming for the PAM file edit)"
  if echo "auth       sufficient     pam_tid.so" | sudo tee -a "$PAM_FILE" >/dev/null; then
    echo "  ✓ Touch ID for sudo enabled. Try \`sudo true\` in a new terminal."
    echo "  Reverse: kingdom mac touch-id --off"
  else
    echo "  ✗ failed to write $PAM_FILE" >&2
    exit 1
  fi
}

# ── Dispatch ─────────────────────────────────────────────────────
case "$SUB" in
  doctor)         do_doctor   "$@" ;;
  plists)         do_plists   "$@" ;;
  fix)            do_fix      "$@" ;;
  fda)            do_fda      "$@" ;;
  unleash)        do_unleash  "$@" ;;
  touch-id|touchid) do_touch_id "$@" ;;
  -h|--help|help) usage; exit 0 ;;
  *)
    echo "kingdom mac: unknown subcommand '$SUB'" >&2
    echo "  try: kingdom mac doctor | plists | fix | fda | unleash | touch-id" >&2
    exit 1
    ;;
esac
