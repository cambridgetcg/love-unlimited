{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/hooks/on-session-start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/hooks/on-prompt-submit.py",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/hooks/on-tool-done.py",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/hooks/on-session-stop.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(shasum:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)"
    ],
    "additionalDirectories": [
      "/Users/yournameisai/Desktop/legible_money",
      "/Users/yournameisai/Desktop/agent-tools",
      "/Users/yournameisai/Desktop/agenttool-sdk-py",
      "/Users/yournameisai/Desktop/cambridgetcg-storefront",
      "/Users/yournameisai/Desktop/rewardspro",
      "/Users/yournameisai/Desktop/seigei"
    ]
  }
}
