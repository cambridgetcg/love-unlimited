#!/bin/sh
# ── kingdom ─────────────────────────────────────────────────────────
# Top-level CLI for the citizen.
#
# Built-in subcommands:
#   help, recite
#
# Plug-in subcommands (auto-discovered):
#   `kingdom <SUB> ...` runs `kingdom-<SUB>` if found on PATH, or
#   `kingdom-<SUB>.sh` in this directory.
#
# Currently shipped:
#   kingdom verify [-v]    Substrate-side covenant check     (HOME.md)
#   kingdom recite         Pretty-print covenant + signature
#   kingdom help           This message
#
# Future plug-ins (separate concerns, separate binaries):
#   kingdom home harden    Chain-side guardian config        (HOME-SAFETY.md)
#   kingdom hive ...       Fleet messaging
#   kingdom fleet ...      Fleet status
#
# Doctrine: kingdom-os/HOME.md (substrate) · HOME-SAFETY.md (chain).
# ─────────────────────────────────────────────────────────────────────
set -e

KINGDOM_BIN_DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")"
HOME_LAYER="${HOME}/.love/home"
COVENANT="${HOME_LAYER}/covenant.json"

show_help() {
  cat <<HELP
kingdom — citizen CLI

Built-in:
  kingdom recite        Print the covenant + signature
  kingdom help          This message

Plug-in (auto-discovered as \`kingdom-<sub>\`):
  kingdom verify [-v]   Substrate-side covenant check  (HOME.md)

  Future: kingdom home harden  — chain-side guardian   (HOME-SAFETY.md)

Doctrine: kingdom-os/HOME.md (substrate) · HOME-SAFETY.md (chain).
HELP
}

case "${1:-help}" in
  recite)
    if [ ! -f "$COVENANT" ]; then
      echo "kingdom: no covenant present at ${COVENANT}" >&2
      echo "  install module 13-covenant to write one" >&2
      exit 1
    fi
    echo "── covenant ──"
    if command -v jq >/dev/null 2>&1; then
      jq . "$COVENANT"
    else
      cat "$COVENANT"
    fi
    echo ""
    if [ -f "${COVENANT}.sig" ]; then
      echo "── signature ──"
      cat "${COVENANT}.sig"
    fi
    ;;

  help|--help|-h|"")
    show_help
    ;;

  *)
    SUB="$1"
    shift
    if command -v "kingdom-${SUB}" >/dev/null 2>&1; then
      exec "kingdom-${SUB}" "$@"
    elif [ -x "${KINGDOM_BIN_DIR}/kingdom-${SUB}.sh" ]; then
      exec "${KINGDOM_BIN_DIR}/kingdom-${SUB}.sh" "$@"
    else
      echo "kingdom: unknown subcommand '$SUB'" >&2
      echo "  try: kingdom help" >&2
      exit 1
    fi
    ;;
esac
